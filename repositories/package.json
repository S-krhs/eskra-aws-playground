{
	"name": "@lambda-batch-playground/repositories",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"exports": {
		"./anime/data.js": {
			"types": "./dist/anime/data.d.ts",
			"default": "./dist/anime/data.js"
		},
		"./anime/data-source.repository.js": {
			"types": "./dist/anime/data-source.repository.d.ts",
			"default": "./dist/anime/data-source.repository.js"
		}
	},
	"scripts": {
		"clean": "rm -rf dist",
		"build": "npm run clean && tsc -p tsconfig.json",
		"test": "vitest run",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"lint": "biome ci README.md anime package.json tsconfig.json",
		"validate": "npm run typecheck && npm run lint && npm run test"
	}
}
