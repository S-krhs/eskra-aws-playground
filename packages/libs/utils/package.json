{
	"name": "@eskra-aws-playground/libs",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"exports": {
		"./date/current-jst-date.js": {
			"types": "./dist/date/current-jst-date.d.ts",
			"default": "./dist/date/current-jst-date.js"
		},
		"./gacha/gacha-pool.js": {
			"types": "./dist/gacha/gacha-pool.d.ts",
			"default": "./dist/gacha/gacha-pool.js"
		},
		"./logger/batch-logger.js": {
			"types": "./dist/logger/batch-logger.d.ts",
			"default": "./dist/logger/batch-logger.js"
		},
		"./string/text-sanitizer.js": {
			"types": "./dist/string/text-sanitizer.d.ts",
			"default": "./dist/string/text-sanitizer.js"
		}
	},
	"scripts": {
		"clean": "rm -rf dist",
		"build": "npm run clean && tsc -p tsconfig.json",
		"test": "vitest run",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"lint": "biome ci .",
		"validate": "npm run typecheck && npm run lint && npm run test"
	},
	"dependencies": {
		"dayjs": "^1.11.21"
	}
}
